#include <Arduino.h>
#include <Keypad.h>
#include <IRremote.hpp>
#include <SPI.h>
#include <MFRC522.h>

enum State { WAITING, LOCKED, UNLOCKED };
State currentState = WAITING;

const int IR_RECEIVE_PIN = 7;

#define SS_PIN 10
#define RST_PIN 9

const int BLUE_LED = A1;
const int RED_LED = A2;
const int GREEN_LED = A3;

const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'}, 
  {'4','5','6','B'},
  {'7','8','9','C'}, 
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {2, 3, 4, 5};
byte colPins[COLS] = {6, A4, 8, A0};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

MFRC522 mfrc522(SS_PIN, RST_PIN);

String masterCode = "";
String enteredIRCode = "";
unsigned long lastPressTime = 0;

char mapIR(long code) {
    switch(code) {
        case 0xF30CFF00: return '1';
        case 0xE718FF00: return '2';
        case 0xA15EFF00: return '3';
        case 0xF708FF00: return '4';
        case 0xE31CFF00: return '5';
        case 0xA55AFF00: return '6';
        case 0xBD42FF00: return '7';
        case 0xAD52FF00: return '8';
        case 0xB54AFF00: return '9';
        case 0xE916FF00: return '0';
        default: return '\0';
    }
}

void setup() {
    Serial.begin(9600);

    SPI.begin();
    mfrc522.PCD_Init();

    IrReceiver.begin(IR_RECEIVE_PIN, ENABLE_LED_FEEDBACK);

    pinMode(BLUE_LED, OUTPUT);
    pinMode(RED_LED, OUTPUT);
    pinMode(GREEN_LED, OUTPUT);

    Serial.println("SYSTEM_READY");
}

void loop() {

    char key = keypad.getKey();

    if (currentState == WAITING) {

        digitalWrite(BLUE_LED, HIGH);
        digitalWrite(RED_LED, LOW);
        digitalWrite(GREEN_LED, LOW);

        if (key != NO_KEY) {
            masterCode += key;

            Serial.print("KEYPAD:");
            Serial.println(masterCode);

            if (masterCode.length() == 4) {
                currentState = LOCKED;
                enteredIRCode = "";
                Serial.println("SYSTEM_LOCKED");
            }
        }
    }

    else if (currentState == LOCKED) {

        digitalWrite(BLUE_LED, LOW);
        digitalWrite(RED_LED, (millis()/500)%2);
        digitalWrite(GREEN_LED, LOW);

        if (IrReceiver.decode()) {

            long raw = IrReceiver.decodedIRData.decodedRawData;

            if (raw == 0xFFFFFFFF) {
                IrReceiver.resume();
                return;
            }

            if (millis() - lastPressTime < 300) {
                IrReceiver.resume();
                return;
            }

            char digit = mapIR(raw);

            if (digit != '\0') {
                enteredIRCode += digit;

                Serial.print("IR:");
                Serial.println(enteredIRCode);

                if (enteredIRCode.length() == 4) {

                    if (enteredIRCode == masterCode) {
                        currentState = UNLOCKED;
                        Serial.println("SYSTEM_UNLOCKED");
                    } else {
                        Serial.println("WRONG_CODE");
                    }

                    enteredIRCode = "";
                }
            }

            lastPressTime = millis();
            IrReceiver.resume();
        }
    }

    else if (currentState == UNLOCKED) {

        digitalWrite(BLUE_LED, LOW);
        digitalWrite(RED_LED, LOW);
        digitalWrite(GREEN_LED, HIGH);

        if (!mfrc522.PICC_IsNewCardPresent()) return;
        if (!mfrc522.PICC_ReadCardSerial()) return;

        String uid = "";

        for (byte i = 0; i < mfrc522.uid.size; i++) {
            uid += String(mfrc522.uid.uidByte[i], HEX);
        }

        uid.toUpperCase();

        Serial.println("RFID_TAG:" + uid);

        mfrc522.PICC_HaltA();

        delay(300);
    }
}
